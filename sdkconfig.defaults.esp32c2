# ===== esp32-c2_defaults =====

# --- LED ------------------------------------------------------------
CONFIG_LED_GPIO=2
CONFIG_LED_ACTIVE_LEVEL=0

# --- Interrupt ------------------------------------------------------
CONFIG_IRQ_OUT_PIN=16
CONFIG_IRQ_OUT_ACTIVE_LEVEL=0

# --- UARTs ----------------------------------------------------------
CONFIG_CONSOLE_UART_NUM=0
CONFIG_COM_UART_NUM=1
CONFIG_COM_USART_RX_PIN=4
CONFIG_COM_USART_TX_PIN=5

# --- SPI (generic slave interface) --------------------------------
CONFIG_COM_SPI_SLAVE=y
CONFIG_COM_SPI_MOSI_PIN=13
CONFIG_COM_SPI_MISO_PIN=14
CONFIG_COM_SPI_SCK_PIN=15
CONFIG_COM_SPI_CS_PIN=16

# --- SDIO (slave) --------------------------------------------------
# ESP32-C2 does **not** include an SDIO slave controller; disable.
CONFIG_COM_SDIO_SLAVE=n
#CONFIG_COM_SDIO_CMD_PIN=
#CONFIG_COM_SDIO_CLK_PIN=
#CONFIG_COM_SDIO_D0_PIN=
#CONFIG_COM_SDIO_D1_PIN=
#CONFIG_COM_SDIO_D2_PIN=
#CONFIG_COM_SDIO_D3_PIN=

# --- QSPI (slave) ---------------------------------------------------
# ESP32-C2 has no QSPI slave support; disable.
CONFIG_COM_QSPI_SLAVE=n
#CONFIG_COM_QSPI_IO0_PIN=
#CONFIG_COM_QSPI_IO1_PIN=
#CONFIG_COM_QSPI_IO2_PIN=
#CONFIG_COM_QSPI_IO3_PIN=
#CONFIG_COM_QSPI_SCK_PIN=
#CONFIG_COM_QSPI_CS_PIN=

# Notes:
# adapt pins if board uses them for other functions
